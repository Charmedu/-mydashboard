# Canvas LMS (generate at canvas.tccd.edu → Account → Settings → New Access Token)
CANVAS_API_TOKEN=your-canvas-api-token-here

# Telegram morning briefing
# 1. Message @BotFather on Telegram → /newbot → copy the token below
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# 2. Message @userinfobot to get your numeric chat ID
TELEGRAM_CHAT_ID=your-numeric-chat-id-here
# 3. Your Google login email (used to look up your data for the cron job)
USER_EMAIL=you@gmail.com
# 4. Random secret to verify Telegram webhook calls (openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here
# 5. Vercel auto-sets CRON_SECRET — add to local .env.local if testing the send endpoint manually
# CRON_SECRET=

# Neon Postgres
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth v5
AUTH_SECRET=your-random-secret-here-run-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
NEXTAUTH_URL=http://localhost:3000
